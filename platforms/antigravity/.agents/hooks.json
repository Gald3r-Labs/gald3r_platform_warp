{
  "gald3r-canonical-hooks": {
    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [
          { "type": "command", "command": "python .agents/hooks/g-hk-ag-dispatch.py tool-start", "timeout": 30 }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          { "type": "command", "command": "python .agents/hooks/g-hk-ag-dispatch.py tool-end", "timeout": 30 }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          { "type": "command", "command": "python .agents/hooks/g-hk-ag-dispatch.py stop", "timeout": 30 }
        ]
      }
    ]
  }
}
