#!/bin/sh
# gald3r pre-commit hook (T1428) -- encoding + line-ending normalization.
# Normalizes staged text files to the correct UTF-8 BOM state (BOM for .ps1/.psm1/.psd1,
# no-BOM otherwise) and LF endings, then re-stages the fixes. Prevents BUG-073 / BUG-094
# corruption from entering history.
#
# This is a POSIX shell shim that delegates to the canonical PowerShell hook so the
# normalization logic lives in exactly one place (g-hk-encoding-normalize.ps1).
#
# Install: run scripts/install_git_hooks.ps1 (sets core.hooksPath to .githooks), or copy
# this file to .git/hooks/pre-commit. Disable: git config --unset core.hooksPath.

set -e

# Resolve the canonical hook across IDE targets (first match wins).
HOOK=""
for p in \
    ".claude/hooks/g-hk-encoding-normalize.ps1" \
    ".cursor/hooks/g-hk-encoding-normalize.ps1" \
    ".claude/hooks/g-hk-encoding-normalize.ps1"
do
    if [ -f "$p" ]; then HOOK="$p"; break; fi
done

if [ -z "$HOOK" ]; then
    # Hook not installed in this project -- do not block the commit.
    exit 0
fi

# Prefer Windows PowerShell 5.1 (default on Windows); fall back to pwsh.
if command -v powershell >/dev/null 2>&1; then
    PS="powershell"
elif command -v pwsh >/dev/null 2>&1; then
    PS="pwsh"
else
    # No PowerShell available -- skip rather than block.
    exit 0
fi

"$PS" -NoProfile -ExecutionPolicy Bypass -File "$HOOK" -PreCommit -Quiet || exit 0
exit 0
