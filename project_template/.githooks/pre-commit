#!/bin/sh
# gald3r pre-commit hook (T1428) -- encoding + line-ending normalization.
# Normalizes staged text files to the correct UTF-8 BOM state (BOM for .ps1/.psm1/.psd1,
# no-BOM otherwise) and LF endings, then re-stages the fixes. Prevents BUG-073 / BUG-094
# corruption from entering history.
#
# This is a POSIX shell shim that delegates to the canonical Python hook so the
# normalization logic lives in exactly one place (g-hk-encoding-normalize.py).
#
# Install: run scripts/install_git_hooks.py (sets core.hooksPath to .githooks), or copy
# this file to .git/hooks/pre-commit. Disable: git config --unset core.hooksPath.

set -e

# Resolve the canonical hook across IDE targets (first match wins).
HOOK=""
for p in \
    ".claude/hooks/g-hk-encoding-normalize.py" \
    ".cursor/hooks/g-hk-encoding-normalize.py"
do
    if [ -f "$p" ]; then HOOK="$p"; break; fi
done

if [ -z "$HOOK" ]; then
    # Hook not installed in this project -- do not block the commit.
    exit 0
fi

# Resolve a Python interpreter; skip rather than block if none available.
if command -v python >/dev/null 2>&1; then
    PY="python"
elif command -v python3 >/dev/null 2>&1; then
    PY="python3"
else
    exit 0
fi

"$PY" "$HOOK" -PreCommit -Quiet || exit 0
exit 0
