# gald3r - Public Repository .gitignore
# Managed by gald3r v1.11.0 - https://github.com/wrm3/gald3r


# ============================================================
# Environment and secrets
# ============================================================
.env
*.env.local

# Machine-specific MCP config (generated per-install, not source)
/.mcp.json

research/

# ============================================================
# Generated / runtime (not source)
# ============================================================

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.venv/
venv/
.pytest_cache/
*.egg-info/
dist/
build/
uv.lock

# Rust / Tauri
target/
Cargo.lock

# Node
node_modules/
package-lock.json

# IDE internals
.vscode/
.idea/
*.swp
*.swo
*~

# Archive files
*.zip
*.rar
*.7z
*.tar.gz



# OS files
.DS_Store
Thumbs.db
desktop.ini

# Docker volumes
postgres_data/

# Logs
*.log
logs/

# Platform docs (generated by crawl4ai, not tracked)
.platforms/

# Worktrees (parallel agent execution)
worktrees/

# Swarm file-lock manifests (T1059) — ephemeral, visible during an active
# g-go --swarm run, never committed. Also listed in .gald3rignore.
.gald3r-swarm-locks/

# Scripts (host-side automation, may contain local paths)
# Ignore scripts/ contents by default; explicitly re-include safe ones below.
# Note: must use /scripts/* (not /scripts/) so negations can re-include files.
/scripts/*
!/scripts/bootstrap_member_gald3r_marker.ps1
!/scripts/check_member_repo_gald3r_guard.ps1
!/scripts/remediate_member_gald3r_marker.ps1
!/scripts/validate_workspace_members_gald3r.ps1

# Research and temp (not tracked in public repo)
research/

# Temp scripts (placeholder only, .gitkeep is tracked)
temp_scripts/*
!temp_scripts/.gitkeep

# Cursor continual-learning state (machine-specific, not source)
.cursor/hooks/state/continual-learning.json
.cursor/hooks/state/continual-learning-index.json

# gald3r live session logs (generated per-session, not starter content)
.gald3r/logs/*.log
!.gald3r/logs/.gitkeep

# T1611: org policy bundle — per-install local state (org-specific), never canonical template
# source and never committed (an org's policy rules should not leak into a shared repo).
.gald3r/policy/


# T1043: generated skills integrity manifest — do not commit
gald3r-skills-lock.json

# T1011: personalized LLM bootstrap (optional — user choice to commit)
# GALD3R-PROMPT.md

